# Copy this file to .env (not committed) and adjust if you wish.
# All values below are also the defaults baked into docker-compose.yml,
# so the project runs even if you never create a .env file.

# --- Postgres ---
POSTGRES_USER=luigi
POSTGRES_PASSWORD=luigi
POSTGRES_DB=charts

# --- pgAdmin (UI: http://localhost:5050) ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
